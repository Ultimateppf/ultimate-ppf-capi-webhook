# Meta Conversions API
META_PIXEL_ID=SEU_PIXEL_ID_AQUI
META_ACCESS_TOKEN=SEU_ACCESS_TOKEN_META_AQUI

# Nuvemshop Webhook Secret
# Encontre em: Nuvemshop Admin → Apps → Webhooks → Secret
NUVEMSHOP_SECRET=SEU_SECRET_NUVEMSHOP_AQUI

# WhatsApp Webhook (para ctwa_clid)
WA_VERIFY_TOKEN=ultimate_ppf_webhook_2026

# Modo teste Meta (deixe vazio em produção)
# META_TEST_EVENT_CODE=TEST12345

# Porta (Railway define automaticamente via $PORT)
# PORT=5001
